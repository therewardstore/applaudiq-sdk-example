# Copy to .env.local (gitignored) and fill in. Read SERVER-SIDE by vite.config.ts to
# inject the mint secret into the /api/mint dev-proxy — these never reach the browser.
# DEMO/TEST ONLY: in production your BACKEND mints the token (see the nextjs example).

# Your aiq_embed_ SECRET (server-only) — HR portal → Settings → Embed SDK Keys.
APPLAUDIQ_SECRET=

# Gateway origin that mints the token (POST /api/v1/embed/sessions).
APPLAUDIQ_API_BASE=http://localhost:8000
