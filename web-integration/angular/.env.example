# DEMO/TEST ONLY. Used by the /api/mint dev-proxy (proxy.conf.js) to inject the mint
# secret server-side — these never reach the browser. In production your BACKEND mints
# the token (see the nextjs example).
#
# NOTE: the Angular CLI does NOT auto-load .env files. Pass these on the dev command:
#   APPLAUDIQ_SECRET=aiq_embed_… APPLAUDIQ_API_BASE=http://localhost:8000 npm start
# Copy this file to .env.local (gitignored) just to keep the values handy.

# Your aiq_embed_ SECRET (server-only) — HR portal → Settings → Embed SDK Keys.
APPLAUDIQ_SECRET=

# Gateway origin that mints the token (POST /api/v1/embed/sessions).
APPLAUDIQ_API_BASE=http://localhost:8000
