# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit your secret.

# Your embed SECRET (aiq_embed_…) — server-only. Generated in HR portal → Settings → Embed SDK Keys.
# Used only by app/api/mint/route.ts to mint one-time tokens. Keep it out of the browser and out of git.
APPLAUDIQ_SECRET=aiq_embed_your_secret_here

# The Applaud IQ API base for minting. Local gateway by default; production is your API base.
APPLAUDIQ_API_BASE=http://localhost:8000
