{
  "name": "applaudiq-cordova-vanilla",
  "private": true,
  "version": "1.0.0",
  "author": "Arulraj V <abofficial1997@gmail.com>",
  "type": "module",
  "description": "Applaud IQ embed — plain Cordova (vanilla TS + Vite) example.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cordova:prepare": "cordova prepare",
    "local:web": "./run-local.sh web",
    "local:ios": "./run-local.sh ios",
    "local:android": "./run-local.sh android"
  },
  "dependencies": {
    "@applaudiq/embed-cordova": "^1.1.1"
  },
  "devDependencies": {
    "cordova": "^12.0.0",
    "cordova-android": "^15.0.0",
    "cordova-ios": "^8.1.0",
    "cordova-plugin-customurlscheme": "^5.0.2",
    "cordova-plugin-inappbrowser": "^6.0.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "cordova": {
    "platforms": [
      "android",
      "ios"
    ],
    "plugins": {
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-customurlscheme": {
        "URL_SCHEME": "aiqexample",
        "ANDROID_SCHEME": " ",
        "ANDROID_HOST": " ",
        "ANDROID_PATHPREFIX": "/"
      }
    }
  }
}
